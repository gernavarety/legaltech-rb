# ═══════════════════════════════════════════════════════════════
# LexAI.by — Переменные окружения
# Скопируйте файл: cp .env.example .env  и заполните значения
# НИКОГДА не коммитьте .env в git — он в .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── LLM провайдер ──────────────────────────────────────────────
# Переключение: ollama | groq | anthropic | openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Получить бесплатно: https://console.groq.com
GROQ_API_KEY=gsk_...

# Получить: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── Эмбеддинги ─────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# Если используете OpenAI эмбеддинги:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ─── Supabase Auth ───────────────────────────────────────────────
# Регистрация: https://supabase.com (бесплатный тариф)
# Проект → Settings → API

# JWT Secret: Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Service Role Key (только для бэкенда, НЕ публичный):
# Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon Key (публичный, используется во фронтенде):
# Settings → API → anon public
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── База данных ─────────────────────────────────────────────────
# Если используете Supabase как БД:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
# Если локальный Docker pgvector:
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@pgvector:5432/legaltech
POSTGRES_PASSWORD=postgres_secure_pass_change_me

# ─── Bepaid.by (платёжный шлюз Беларуси) ────────────────────────
# Регистрация магазина: https://bepaid.by
# После регистрации: Личный кабинет → Настройки → API

# ID магазина (числовой, например: 12345)
BEPAID_SHOP_ID=

# Секретный ключ магазина
BEPAID_SECRET_KEY=

# Публичный ключ магазина
BEPAID_PUBLIC_KEY=

# true = тестовый режим (карты Bepaid из документации)
# false = боевой режим (реальные деньги!)
BEPAID_TEST_MODE=true

# Секрет для верификации вебхуков (придумайте сами, длинная случайная строка)
WEBHOOK_SECRET=change_me_to_random_32_char_string

# ─── Email (Resend.com) ──────────────────────────────────────────
# Регистрация: https://resend.com (бесплатно 3000 писем/мес)
# API Keys → Create API Key
RESEND_API_KEY=re_...

# Email-отправитель (должен быть верифицирован в Resend)
FROM_EMAIL=noreply@lexai.by

# ─── URLs ────────────────────────────────────────────────────────
# Публичный URL фронтенда (без слэша в конце)
FRONTEND_URL=http://localhost:3000
# В продакшне: FRONTEND_URL=https://lexai.by

# URL бэкенда (для Next.js rewrite proxy)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Cloudflare R2 (файловое хранилище) ─────────────────────────
# Регистрация: https://cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=legaltech-rb
# R2_ENDPOINT_URL=  # оставьте пустым, строится автоматически

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Настройки приложения ────────────────────────────────────────
MAX_FILE_SIZE_MB=10
CLAUDE_TIMEOUT_SECONDS=120
