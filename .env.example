# ═══════════════════════════════════════════════════════════════
# LegalTech RB — Переменные окружения
# Скопируйте в .env и заполните свои значения
# ═══════════════════════════════════════════════════════════════

# ─── Anthropic Claude API ───────────────────────────────────────
# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── OpenAI API (только для эмбеддингов) ───────────────────────
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── PostgreSQL ─────────────────────────────────────────────────
# Пароль для PostgreSQL (используется в docker-compose)
POSTGRES_PASSWORD=postgres_secure_pass

# ─── Supabase (альтернатива локальному PostgreSQL) ──────────────
# Если используете Supabase вместо локального pgvector:
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres

# ─── Cloudflare R2 ──────────────────────────────────────────────
# Получить в панели Cloudflare → R2 Object Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=legaltech-rb
# Опционально: кастомный endpoint (обычно не нужен)
# R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Frontend ───────────────────────────────────────────────────
# URL бэкенда, доступный из браузера пользователя
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Настройки приложения ────────────────────────────────────────
# Максимальный размер загружаемого файла в МБ
MAX_FILE_SIZE_MB=10

# Таймаут запроса к Claude API в секундах
CLAUDE_TIMEOUT_SECONDS=120

# Модель Claude для анализа
CLAUDE_MODEL=claude-sonnet-4-6

# Модель OpenAI для эмбеддингов
EMBEDDING_MODEL=text-embedding-3-small
